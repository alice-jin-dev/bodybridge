// secrets.h.example — bodybridge ESP32 firmware secrets TEMPLATE.
//
// Copy this file to `secrets.h` in the SAME directory, then fill in real values:
//     cp secrets.h.example secrets.h
// (or just copy it in your file manager / Arduino IDE).
//
// `secrets.h` is git-ignored (`**/secrets.h`) and must NEVER be committed.
// This `.example` file holds only placeholders and is safe to commit.
//
// If you clone this repo and try to build without creating secrets.h, the
// compile will fail on `#include "secrets.h"` — that is expected. Copy this
// template first.

#ifndef BODYBRIDGE_SECRETS_H
#define BODYBRIDGE_SECRETS_H

// --- WiFi (2.4 GHz only — classic ESP32 has no 5 GHz radio) ---
#define WIFI_SSID      "your-2.4GHz-wifi-ssid"
#define WIFI_PASSWORD  "your-wifi-password"

// --- bodybridge device credential ---
// The Bearer token this device presents when connecting to the bridge's
// /device endpoint. It must EXACTLY match BODYBRIDGE_DEVICE_TOKEN set on the
// bridge (e.g. in Zeabur's environment variables). A leaked token means
// someone can drive your device — treat it like a password; if it leaks,
// rotate it on both the bridge and here.
#define BODYBRIDGE_DEVICE_TOKEN  "paste-your-device-token-here"

// --- bridge address (not a secret, but kept here so all deployment config
//     lives in one file). BRIDGE_HOST is a PLACEHOLDER on purpose — set it to
//     your own bridge's host. It is deliberately left un-real: if you forget
//     to change it, DNS fails loudly with "host not found" and one glance
//     tells you to fix the host. A real default here would instead silently
//     resolve to someone else's bridge and return a confusing 403, sending
//     you hunting your token when the real mistake is the host — a lying
//     error message (iron rule 4). Path stays /device. ---
#define BRIDGE_HOST    "your-bridge.example.com"
#define BRIDGE_PORT    443            // 443 = wss (TLS). Required for the public bridge.
#define BRIDGE_PATH    "/device"

#endif  // BODYBRIDGE_SECRETS_H
