# bodybridge configuration template.
# Copy this file to `.env` and fill in your own values:  cp .env.example .env
# Never commit your real `.env` — it holds secrets.

# ============================================================
# Required — no safe default, you MUST set this.
# ============================================================

# Shared secret for authenticating requests to the bridge.
# Without it the bridge refuses to start (it would otherwise be open to anyone).
# Use a long random string; if it ever leaks, revoke it and issue a new one.
BODYBRIDGE_TOKEN=replace-with-a-long-random-secret

# Password that gates /oauth/authorize (the consent page CIMD clients like
# claude.ai use to obtain a token). Without it that page can never succeed,
# so the bridge refuses to start rather than run with OAuth silently broken.
# Use a long random string; if it ever leaks, revoke it and issue a new one.
BODYBRIDGE_PASSWORD=replace-with-a-long-random-secret

# ============================================================
# Optional — sensible defaults, override only if you need to.
# ============================================================

# Network interface the bridge binds to.
# 127.0.0.1 = local-only (good for testing on your own machine).
# Set to 0.0.0.0 when deploying to the cloud so it accepts external connections.
BODYBRIDGE_HOST=127.0.0.1

# TCP port the bridge listens on.
BODYBRIDGE_PORT=8000

# Public base URL of the bridge, used in the OAuth discovery metadata that
# claude.ai reads to connect (RFC 9728 / RFC 8414).
# Format: scheme + host (+ port), NO trailing slash, NO /mcp path — the code
# appends /mcp itself. Example: https://bridge.example.com
# Required for real (public) deployment: CIMD discovery from claude.ai needs a
# public HTTPS base URL, and the metadata's `resource` must match the URL the
# user types into Claude exactly. If unset, the bridge falls back to
# http://<host>:<port> (fine for local testing) and prints a startup warning.
BODYBRIDGE_PUBLIC_URL=https://bridge.example.com

# Comma-separated host allowlist for CIMD client_id fetches (SSRF hardening).
# Default (unset/empty): general protection only -- any https host is allowed
# EXCEPT private/loopback/link-local/reserved addresses (blocked regardless).
# Set this to restrict CIMD fetches to specific known client hosts if you want
# to lock the bridge down further; leave unset for "any MCP client can connect".
# Example: BODYBRIDGE_CIMD_ALLOWLIST=claude.ai,some-other-client.example.com
BODYBRIDGE_CIMD_ALLOWLIST=

# How many days an issued access token stays valid. There is no refresh token
# in V1 -- once it expires, the client must go through /oauth/authorize again.
# Default: 7. If unset, 7 is used silently (this is a free choice, not a
# required setting). If set to something that isn't a positive number, the
# bridge falls back to 7 and prints a startup warning (it still starts).
BODYBRIDGE_TOKEN_TTL_DAYS=7
