# bodybridge configuration template.
# Copy this file to `.env` and fill in your own values:  cp .env.example .env
# Never commit your real `.env` — it holds secrets.

# ============================================================
# Required — no safe default, you MUST set this.
# ============================================================

# Shared secret for authenticating requests to the bridge.
# Without it the bridge refuses to start (it would otherwise be open to anyone).
# Use a long random string; if it ever leaks, revoke it and issue a new one.
BODYBRIDGE_TOKEN=replace-with-a-long-random-secret

# Password that gates /oauth/authorize (the consent page OAuth clients like
# claude.ai use to obtain a token). Without it that page can never succeed,
# so the bridge refuses to start rather than run with OAuth silently broken.
# Use a long random string; if it ever leaks, revoke it and issue a new one.
BODYBRIDGE_PASSWORD=replace-with-a-long-random-secret

# ============================================================
# Optional — sensible defaults, override only if you need to.
# ============================================================

# Network interface the bridge binds to.
# Default: 0.0.0.0 (all interfaces) -- the bridge is meant to be reached from
# the outside, and auth is mandatory regardless (BODYBRIDGE_TOKEN/PASSWORD
# refuse to start if missing), so listening everywhere by default is safe.
# You normally do NOT need to set this on a cloud platform. Set it to
# 127.0.0.1 only if you specifically want local-only access (e.g. testing
# behind your own reverse proxy).
BODYBRIDGE_HOST=0.0.0.0

# TCP port the bridge listens on. Priority: PORT (the platform-injected
# variable most cloud platforms -- Heroku, Railway, Render, Zeabur, etc. --
# use to tell your app which port to listen on) > BODYBRIDGE_PORT (this
# variable) > 8000 (default). You normally do NOT need to set either on a
# cloud platform -- the platform's own PORT is picked up automatically.
# Set BODYBRIDGE_PORT only for local development or platforms that don't
# inject PORT.
BODYBRIDGE_PORT=8000

# Public base URL of the bridge, used in the OAuth discovery metadata that
# claude.ai reads to connect (RFC 9728 / RFC 8414).
# Format: scheme + host (+ port), NO trailing slash, NO /mcp path — the code
# appends /mcp itself. Example: https://bridge.example.com
# Required for real (public) deployment: CIMD discovery from claude.ai needs a
# public HTTPS base URL, and the metadata's `resource` must match the URL the
# user types into Claude exactly. If unset, the bridge falls back to
# http://<host>:<port> (fine for local testing) and prints a startup warning.
BODYBRIDGE_PUBLIC_URL=https://bridge.example.com

# How the bridge learns who an MCP client is when it connects. Two options:
#   dcr  (default) -- Dynamic Client Registration (RFC 7591). The client
#        POSTs to /oauth/register and we hand back a self-signed client_id;
#        no outbound request is ever made. Recommended: this is what avoids
#        the Cloudflare-challenge 403 seen fetching claude.ai's CIMD document
#        (see MIGRATION.md).
#   cimd -- Client ID Metadata Documents. The client's client_id is an
#        https:// URL and the bridge fetches it (outbound request, subject
#        to SSRF hardening and to whatever WAF/anti-bot protection sits in
#        front of that URL). Kept fully working and can be switched back to
#        at any time -- e.g. if the Cloudflare-challenge issue above gets
#        resolved upstream.
# Unset = dcr (silently, this is a free choice). A value that's neither
# "dcr" nor "cimd" falls back to "dcr" with a startup warning (it still
# starts). Case-insensitive.
BODYBRIDGE_CLIENT_REGISTRATION=dcr

# Comma-separated host allowlist for CIMD client_id fetches (SSRF hardening).
# Only relevant when BODYBRIDGE_CLIENT_REGISTRATION=cimd -- ignored under the
# default dcr mode, since dcr never makes an outbound fetch at all.
# Default (unset/empty): general protection only -- any https host is allowed
# EXCEPT private/loopback/link-local/reserved addresses (blocked regardless).
# Set this to restrict CIMD fetches to specific known client hosts if you want
# to lock the bridge down further; leave unset for "any MCP client can connect".
# Example: BODYBRIDGE_CIMD_ALLOWLIST=claude.ai,some-other-client.example.com
BODYBRIDGE_CIMD_ALLOWLIST=

# How many days an issued access token stays valid. There is no refresh token
# in V1 -- once it expires, the client must go through /oauth/authorize again.
# Default: 7. If unset, 7 is used silently (this is a free choice, not a
# required setting). If set to something that isn't a positive number, the
# bridge falls back to 7 and prints a startup warning (it still starts).
BODYBRIDGE_TOKEN_TTL_DAYS=7

# Bridge-side deadline (in seconds) for a single device command. If the device
# doesn't respond within this window, the bridge stops waiting and returns a
# `timeout` result telling the caller the command may or may not have run --
# it never hangs forever. Covers all three device tools (list_capabilities,
# get_status, send_command) equally.
# Default: 25. If unset, 25 is used silently (a free choice, not required). If
# set to something that isn't a positive number, the bridge falls back to 25
# and prints a startup warning (it still starts).
BODYBRIDGE_COMMAND_TIMEOUT_SECONDS=25

# ============================================================
# Device layer (layer 3) — for connecting a physical device.
# ============================================================

# Bearer token a device (e.g. ESP32 firmware) presents when it connects to the
# /device WebSocket endpoint. This is NOT the same as BODYBRIDGE_TOKEN:
#   - BODYBRIDGE_TOKEN is the server's own JWT SIGNING secret — a server-side
#     secret that is never handed to any device or client.
#   - BODYBRIDGE_DEVICE_TOKEN is the credential the device itself presents.
# Optional, and NOT fail-fast: if unset, the /device endpoint is disabled (no
# device can connect) and the bridge prints a startup warning, but it still
# starts normally — /mcp and OAuth are unaffected. Set it only when you're
# ready to connect a real device.
# Use a long random string; if it ever leaks, revoke it and issue a new one
# (a leaked device token means someone can drive your device — see the V1
# "what we don't defend against" list).
BODYBRIDGE_DEVICE_TOKEN=
